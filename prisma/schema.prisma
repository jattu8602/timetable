generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Department {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  shortCode String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  program      String
  departmentId String   @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, program, departmentId])
}

model Room {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  number       String
  name         String?
  departmentId String   @db.ObjectId
  capacity     Int
  type         String   @default("classroom")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([number, departmentId])
}

model Course {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  code         String
  name         String
  credits      Float
  type         String
  courseType   String
  branchId     String   @db.ObjectId
  semester     String
  departmentId String   @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([code, branchId, semester])
}

model Faculty {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  departmentId String   @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CourseFaculty {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  courseId   String @db.ObjectId
  facultyId String @db.ObjectId

  @@unique([courseId, facultyId])
}

model Timetable {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  institution  String
  academicTerm String
  departmentId String   @db.ObjectId
  program      String
  branchId     String   @db.ObjectId
  semesterName String
  wefDate      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TimeSlot {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  timetableId    String @db.ObjectId
  dayOfWeek      String
  periodName     String
  timeRange      String
  subjectDetails String
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  password     String
  role         String   @default("admin")
  departmentId String?  @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
