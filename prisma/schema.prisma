generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  coordinator
  professor
  hod
  dean
  faculty
}

enum RoomType {
  classroom
  lab
  other
}

enum CourseType {
  lecture
  lab
  tutorial
  elective
  project
  activity
}

model Department {
  id        String    @id @default(uuid())
  name      String
  shortCode String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches   Branch[]
  rooms      Room[]
  courses    Course[]
  faculty    Faculty[]
  users      User[]
  timetables Timetable[]
}

model Branch {
  id           String    @id @default(uuid())
  name         String
  program      String
  departmentId String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department  Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses     Course[]
  timetables  Timetable[]

  @@unique([name, program, departmentId])
}

model Room {
  id           String    @id @default(uuid())
  number       String
  name         String?
  departmentId String
  capacity     Int
  type         RoomType  @default(classroom)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([number, departmentId])
}

model Course {
  id           String     @id @default(uuid())
  code         String
  name         String
  credits      Float
  type         CourseType
  courseType   String
  branchId     String
  semester     String
  departmentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  branch     Branch          @relation(fields: [branchId], references: [id])
  department Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  faculty    CourseFaculty[]

  @@unique([code, branchId, semester])
}

model Faculty {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  departmentId String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses    CourseFaculty[]
}

model CourseFaculty {
  courseId  String
  facultyId String

  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@id([courseId, facultyId])
}

model Timetable {
  id           String    @id @default(uuid())
  institution  String
  academicTerm String
  departmentId String
  program      String
  branchId     String
  semesterName String
  wefDate      DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department @relation(fields: [departmentId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])
  slots      TimeSlot[]
}

model TimeSlot {
  id             String @id @default(uuid())
  timetableId    String
  dayOfWeek      String
  periodName     String
  timeRange      String
  subjectDetails String

  timetable Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(admin)
  departmentId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department? @relation(fields: [departmentId], references: [id])
  accounts   Account[]
  sessions   Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
